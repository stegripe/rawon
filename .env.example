# Essential configuration for Rawon Discord Bot
# Copy this file to .env and fill in the required values
# For additional optional and/or developer configuration options, see dev.env.example

# Discord bot tokens (get from https://discord.com/developers/applications)
# Use comma-separated tokens to enable multi-bot mode
# Required, no default
DISCORD_TOKEN=""

# Stegripe API access keys
# Both keys require contacting Stegripe staff through https://stegripe.org/discord
# STEGRIPE_API_LICENSE_KEY is required for licensed features
# STEGRIPE_API_LYRICS_TOKEN is required for lyrics command accuracy
# 1. Start the bot once
# 2. Copy the Bot ID from the license warning
# 3. Join [stegripe.org/discord](https://stegripe.org/discord)
# 4. Send the Bot ID to Stegripe staff for review
# 5. After approval, set STEGRIPE_API_LICENSE_KEY here and restart the bot
STEGRIPE_API_URL="https://api.stegripe.org"
STEGRIPE_API_LICENSE_KEY=""
STEGRIPE_API_LYRICS_TOKEN=""

# Spotify API credentials (get from https://developer.spotify.com/dashboard)
# Required for Spotify support, no default
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Main command prefix
# Default: !
MAIN_PREFIX=""

# Main server ID for slash command registration
# Optional, no default
MAIN_SERVER=""

# Bot developer IDs (comma-separated)
# Optional, no default
DEVS=""

# Bot language
# Available: en-US, es-ES, fr-FR, id-ID, zh-CN, zh-TW, uk-UA, vi-VN, pt-BR, ru-RU, ja-JP, tr-TR, ko-KR
# Default: en-US
LOCALE=""

# Activity types for each activity above (comma-separated)
# Available: PLAYING, WATCHING, LISTENING, COMPETING
# Default: PLAYING
ACTIVITY_TYPES="PLAYING, LISTENING, WATCHING, PLAYING"

# Bot status activities (comma-separated)
# Formats: {prefix}, {userCount}, {textChannelCount}, {serverCount}, {playingCount}, {username}
# Default: none
ACTIVITIES="My default prefix is {prefix}, music with {userCount} users, {textChannelCount} text channels in {serverCount} guilds, 'Hello there, my name is {username}'"
